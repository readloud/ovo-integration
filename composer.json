{
    "name": "svn/ovoid",
    "description": "OVO ID Un - Official API Integration with Signature Support for Multiple Transfers",
    "type": "library",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^6.0",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "symfony/var-dumper": "^8.1",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "files":[
          "src/helper/function.php"
        ],
        "psr-4": {
            "Svn\\OVOID\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Svn\\OVOID\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "svn",
            "email": "svn@example.com"
        }
    ],
    "license": "MIT"
}
